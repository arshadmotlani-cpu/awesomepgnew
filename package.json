{
  "name": "awesomepg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/db/startupMigrationGate.ts && next dev",
    "env:pull": "npx vercel env pull .env.local --environment=preview",
    "env:check": "tsx scripts/check-env.ts",
    "db:status": "tsx src/db/migrationStatus.ts",
    "build": "next build",
    "vercel-build": "bash scripts/vercel-build.sh",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:studio": "drizzle-kit studio",
    "neon:cleanup-branches": "tsx scripts/cleanup-neon-preview-branches.ts",
    "neon:cleanup-branches:execute": "tsx scripts/cleanup-neon-preview-branches.ts --execute",
    "test": "npx tsx scripts/lint-image-uploads.ts && npx tsx scripts/lint-private-blob-display.ts && node scripts/run-unit-tests.mjs",
    "test:ci": "npx tsx scripts/lint-image-uploads.ts && npx tsx scripts/lint-private-blob-display.ts && TEST_CONCURRENCY=1 node scripts/run-unit-tests.mjs",
    "test:billing-settlement": "npx tsx --test tests/unit/billingEngineValidation.test.ts tests/unit/moveOutSettlementExplanation.test.ts tests/unit/settlementRuleRegistry.test.ts tests/unit/billingCoverageRegression.test.ts",
    "lint:uploads": "tsx scripts/lint-image-uploads.ts",
    "lint:private-blobs": "tsx scripts/lint-private-blob-display.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test tests/e2e/smoke.spec.ts",
    "prepare": "bash scripts/install-git-hooks.sh",
    "docs:sync": "tsx scripts/sync-docs-pre-commit.ts",
    "docs:check": "tsx scripts/sync-docs-pre-commit.ts --check",
    "docs:links": "tsx scripts/verify-docs-links.ts",
    "capital:db:generate": "drizzle-kit generate --config capital/drizzle.config.ts",
    "capital:db:migrate": "tsx src/capital/db/migrate.ts",
    "capital:db:seed": "tsx src/capital/db/seed.ts",
    "capital:db:studio": "drizzle-kit studio --config capital/drizzle.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@sentry/nextjs": "^10.57.0",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.9",
    "posthog-js": "^1.386.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.49.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
