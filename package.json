{
  "name": "awesomepg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/db/startupMigrationGate.ts && next dev",
    "env:pull": "npx vercel env pull .env.local --environment=preview",
    "env:check": "tsx scripts/check-env.ts",
    "db:status": "tsx src/db/migrationStatus.ts",
    "build": "next build",
    "vercel-build": "npm run db:migrate && bash scripts/vercel-build-repair.sh && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:studio": "drizzle-kit studio",
    "test": "npx tsx scripts/lint-image-uploads.ts && npx tsx scripts/lint-private-blob-display.ts && npx tsx --test 'tests/unit/**/*.test.ts' 'tests/integration/**/*.test.ts'",
    "test:ci": "npx tsx scripts/lint-image-uploads.ts && npx tsx scripts/lint-private-blob-display.ts && npx tsx --test --test-concurrency=1 'tests/unit/**/*.test.ts' 'tests/integration/**/*.test.ts'",
    "lint:uploads": "tsx scripts/lint-image-uploads.ts",
    "lint:private-blobs": "tsx scripts/lint-private-blob-display.ts",
    "test:e2e": "playwright test",
    "prepare": "bash scripts/install-git-hooks.sh",
    "docs:sync": "tsx scripts/sync-docs-pre-commit.ts",
    "docs:check": "tsx scripts/sync-docs-pre-commit.ts --check",
    "docs:links": "tsx scripts/verify-docs-links.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.57.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "next": "16.2.6",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.9",
    "posthog-js": "^1.386.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.49.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
