{
  "name": "awesomepg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/db/startupMigrationGate.ts && next dev",
    "db:status": "tsx src/db/migrationStatus.ts",
    "build": "next build",
    "vercel-build": "npm run db:migrate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:studio": "drizzle-kit studio",
    "test": "node --import tsx --test 'tests/unit/**/*.test.ts'"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.57.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.10",
    "postgres": "^3.4.9",
    "posthog-js": "^1.386.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.49.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
