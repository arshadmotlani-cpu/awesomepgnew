{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/(admin)/admin/page.tsx": {
      "maxDuration": 60
    },
    "app/api/webhooks/vercel/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/deploy-watchdog/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/release-holds",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/generate-monthly-rent",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/expire-bed-reserves",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/automation",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/financial-reconciliation",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/expire-fixed-stays",
      "schedule": "0 * * * *"
    }
  ]
}
